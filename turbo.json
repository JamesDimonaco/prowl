{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "CONVEX_DEPLOYMENT",
    "CONVEX_DEPLOY_KEY",
    "CONVEX_SITE_URL",
    "NEXT_PUBLIC_CONVEX_URL",
    "NEXT_PUBLIC_CONVEX_SITE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "SITE_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "SCRAPER_URL",
    "SCRAPER_API_KEY",
    "RESEND_API_KEY",
    "ANTHROPIC_API_KEY",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "POLAR_ACCESS_TOKEN",
    "POLAR_PRO_PRODUCT_ID",
    "POLAR_MAX_PRODUCT_ID",
    "POLAR_ENVIRONMENT",
    "POLAR_WEBHOOK_SECRET",
    "GOOGLE_SITE_VERIFICATION"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}
