# Scraper API
# Generate with: openssl rand -hex 32
SCRAPER_API_KEY=your-secret-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
# Comma-separated list of allowed CORS origins (leave empty in production for backend-only service)
ALLOWED_ORIGINS=

# Convex
CONVEX_DEPLOYMENT=your-convex-deployment
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site

# Scraper URL (for Next.js API proxy and Convex scheduler)
# Local: http://localhost:3001
# Production: https://your-scraper.railway.app (or wherever it's deployed)
SCRAPER_URL=http://localhost:3001

# Better Auth
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your-random-secret
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Notifications (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
RESEND_API_KEY=your-resend-api-key
